#!/bin/sh
# Pizza Robot Studios pre-commit hook: block commits that look like they
# contain API keys. Mandated by the global CLAUDE.md. Patterns cover the
# providers we use; expand here if a new provider is added to the stack.
#
# Note on the `re_` pattern: real Resend keys are ~35 chars after `re_`.
# Bumping the minimum suffix length to 30 avoids matching legit identifiers
# in the codebase like `re_payments_integration` (the AgentCore Payments
# integration id; false positive seen 2026-05-14 during the audit pass).
PATTERNS="sk-ant-[a-zA-Z0-9_-]{20,}|sk-proj-[a-zA-Z0-9_-]{30,}|AIza[0-9A-Za-z_-]{35}|re_[a-zA-Z0-9_-]{30,}|xoxb-[a-zA-Z0-9-]{20,}|github_pat_[a-zA-Z0-9_]{50,}|ghp_[a-zA-Z0-9]{36}|gho_[a-zA-Z0-9]{36}|ghs_[a-zA-Z0-9]{36}|-----BEGIN [A-Z ]*PRIVATE KEY-----"
if git diff --cached | grep -qE "$PATTERNS"; then
  echo "COMMIT BLOCKED: possible API key detected in staged changes."
  echo "Remove the key from the diff, move it behind process.env / wrangler secret put, then retry."
  exit 1
fi

# Em-dash gate (audit #6, 2026-05-28): the no-em-dash rule is strictest on
# indexed and user-facing surfaces, where a U+2014 is the clearest AI tell.
# Block staged ADDITIONS containing an em dash in the frontend, the MCP
# server, and the public text feeds. EMDASH is built via printf so this hook
# itself stays em-dash-free. Worker source is excluded on purpose: it holds
# the legitimate EM_DASH detector constants the validators grep against.
EMDASH=$(printf '\xe2\x80\x94')
if git diff --cached --diff-filter=d -- 'src/app' 'mcp-server/src' 'public/llms.txt' 'public/originals.xml' | grep -E '^\+' | grep -q "$EMDASH"; then
  echo "COMMIT BLOCKED: em dash (U+2014) in a staged user-facing change."
  echo "Replace it with a colon, period, comma, or parentheses (project rule #1), then retry."
  exit 1
fi

# Originals completeness gate. The on-rig daily-article cadence writes drafts to the
# working tree for review, so a direct push to main deploys whatever gets committed;
# this is the real backstop. When a commit touches any originals surface, the set must
# stay in sync AND complete: no retired byline, every article has its OG shim, the newest
# article has a hero. scripts/check-originals-sync.mjs reads the working tree and exits
# non-zero on any drift, blocking a broken or half-finished article from being committed.
if git diff --cached --name-only | grep -qE '^(src/app/originals/|src/lib/originals-directory\.ts|src/app/sitemap\.ts|public/llms\.txt)'; then
  if ! node scripts/check-originals-sync.mjs; then
    echo "COMMIT BLOCKED: originals sync-check failed (see above)."
    echo "Fix the byline, hero, OG shim, or registration, then retry."
    exit 1
  fi
fi
