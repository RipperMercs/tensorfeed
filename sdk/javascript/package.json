{
  "name": "tensorfeed",
  "version": "2.3.1",
  "description": "JavaScript/TypeScript SDK for the TensorFeed.ai API: AI news, status, model pricing, benchmarks, premium history series, webhook watches, Vercel AI SDK + LangChain.js tool factories, and agent-payable premium routing (USDC on Base)",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./ai": {
      "types": "./dist/ai.d.ts",
      "import": "./dist/ai.js"
    },
    "./langchain": {
      "types": "./dist/langchain.d.ts",
      "import": "./dist/langchain.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "npm run build && node --test \"tests/**/*.test.mjs\"",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "tensorfeed",
    "ai",
    "agents",
    "x402",
    "usdc",
    "base",
    "model-routing",
    "llm",
    "api",
    "stablecoin",
    "news",
    "status",
    "models"
  ],
  "author": "TensorFeed.ai",
  "license": "MIT",
  "homepage": "https://tensorfeed.ai/developers/agent-payments",
  "bugs": {
    "url": "https://github.com/RipperMercs/tensorfeed/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/RipperMercs/tensorfeed"
  },
  "engines": {
    "node": ">=18"
  },
  "peerDependencies": {
    "ai": ">=3.0.0",
    "@langchain/core": ">=0.3.0",
    "zod": ">=3.23.0"
  },
  "peerDependenciesMeta": {
    "ai": {
      "optional": true
    },
    "@langchain/core": {
      "optional": true
    },
    "zod": {
      "optional": true
    }
  },
  "devDependencies": {
    "typescript": "^5.0.0"
  }
}
