  "sideEffects": ["./index.js"],
  "keywords": [
    "tensorfeed",
    "ai",
    "llm",
    "status",
    "monitor",
    "uptime",
    "widget",
    "web-component",
    "embed",
    "openai",
    "anthropic",
    "claude",
    "gemini"
  ],
  "homepage": "https://tensorfeed.ai/embed",
  "repository": {
    "type": "git",
    "url": "https://github.com/RipperMercs/tensorfeed.git",
    "directory": "packages/status-widget"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  }
