# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
node_modules/
/.pnp
.pnp.js
.yarn/install-state.gz

# testing
/coverage

# next.js
/.next/
/out/

# production
/build
dist/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# MCP bundle build output (`mcpb pack`). Large binary, not source.
mcp-server/*.mcpb

# env files (NONE of these may ever be committed)
.env
.env.*
worker/.env
worker/.env.*
*.env
mcp-server/.env
mcp-server/.env.*

# secrets directories and ad-hoc key files
secrets/
*.key
*.pem.bak

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# mcp-publisher binary (downloaded from github releases, not source)
mcp-server/.bin/

# mcp-publisher private key (NEVER commit)
.mcp-key

# DNS auth private keys for the MCP registry
mcp-server/.secrets/
**/.secrets/

# Cloned MCP registry repo (used to build the publisher CLI; not source)
mcp-server/registry/

# Claude Code internal state (per-session, not source)
.claude/scheduled_tasks.lock
.claude/*.lock
.claude/commands/

# Playwright MCP scratch output: page snapshots, console logs, and
# transient screenshots from automated mobile/visual checks. Tooling
# artifact, never source.
.playwright-mcp/

# Internal-only docs (Pizza Robot Studios public-repo policy).
# Public-facing READMEs and CHANGELOGs are still tracked; these three
# leak internal strategy / architecture / maintainer-only ops, so they
# live locally only.
CLAUDE.md
docs/ARCHITECTURE.md
sdk/python/PUBLISHING.md

# Local-only spec / planning files (public-repo policy)
specs/

# Stray build / prebuild stdout dumps (not source)
build-output.txt

# Local-only operator scripts (one-off helpers from PR-submission, audit,
# token-mint, and notebook-builder workflows). These are internal tooling
# that wraps live credentials and registry binaries; the canonical scripts
# (fetch-feeds, generate-llms-full, push-to-huggingface, etc.) stay tracked.
scripts/build-cookbook-notebook.py
scripts/build-oai-cookbook-nb.py
scripts/fetch-oai-mcp-nb.py
scripts/inspect-cookbook.py
scripts/oai-mcp-guide.ipynb
scripts/validate-cookbook-nb.py
scripts/push-via-gh-api.py
scripts/mint-test-token.ps1
scripts/phase-2-premium-audit.ps1
scripts/mcp-registry/

# Local-only weekly-update notes + widget debug screenshots (housekeeping)
WEEKLY_UPDATE_*.md
widget-fix-*.png
