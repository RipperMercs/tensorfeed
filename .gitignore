# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
node_modules/
/.pnp
.pnp.js
.yarn/install-state.gz

# testing
/coverage

# next.js
/.next/
/out/

# production
/build
dist/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# env files (NONE of these may ever be committed)
.env
.env.*
worker/.env
worker/.env.*
*.env
mcp-server/.env
mcp-server/.env.*

# secrets directories and ad-hoc key files
secrets/
*.key
*.pem.bak

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# mcp-publisher binary (downloaded from github releases, not source)
mcp-server/.bin/

# mcp-publisher private key (NEVER commit)
.mcp-key

# DNS auth private keys for the MCP registry
mcp-server/.secrets/
**/.secrets/

# Cloned MCP registry repo (used to build the publisher CLI; not source)
mcp-server/registry/
