/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=(), usb=(), interest-cohort=()
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  Cross-Origin-Opener-Policy: same-origin-allow-popups
  Cross-Origin-Resource-Policy: cross-origin
  Content-Security-Policy: default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; form-action 'self'; upgrade-insecure-requests; script-src 'self' 'unsafe-inline' https://static.cloudflareinsights.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' data: https://fonts.gstatic.com; img-src 'self' data: blob: https:; media-src 'self' https:; connect-src 'self' https://tensorfeed.ai https://terminalfeed.io https://vr.org https://api.tensorfeed.ai; frame-src 'none'; manifest-src 'self'; worker-src 'self' blob:

# JSON, RSS, and llms.txt feeds: allow cross-origin reads (they are public).
/feed.xml
  Access-Control-Allow-Origin: *
  Cache-Control: public, max-age=300

/feed.json
  Access-Control-Allow-Origin: *
  Cache-Control: public, max-age=60

/feed/*
  Access-Control-Allow-Origin: *
  Cache-Control: public, max-age=300

/llms.txt
  Access-Control-Allow-Origin: *
  Cache-Control: public, max-age=3600

/llms-full.txt
  Access-Control-Allow-Origin: *
  Cache-Control: public, max-age=3600

# Embeddable widget surfaces. The default site policy is X-Frame-Options
# DENY plus CSP frame-ancestors 'none'. For /widget/* we drop
# X-Frame-Options entirely (ALLOWALL is not a valid value and is ignored
# by browsers anyway) and rely on CSP frame-ancestors * , the correct
# modern directive, so any third-party site can iframe the widget.
# Aggressive cache: widget HTML is static at build, live data is fetched
# client-side from /api/status/summary and /api/probe/latest.
/widget/*
  ! X-Frame-Options
  Content-Security-Policy: default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors *; form-action 'self'; script-src 'self' 'unsafe-inline' https://static.cloudflareinsights.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' data: https://fonts.gstatic.com; img-src 'self' data: blob: https:; connect-src 'self' https://tensorfeed.ai https://api.tensorfeed.ai
  Access-Control-Allow-Origin: *
  Cache-Control: public, max-age=300, s-maxage=300

/openapi.json
  Access-Control-Allow-Origin: *
  Cache-Control: public, max-age=3600

/openapi.yaml
  Access-Control-Allow-Origin: *
  Cache-Control: public, max-age=3600
  Content-Type: application/yaml; charset=utf-8

/postman-collection.json
  Access-Control-Allow-Origin: *
  Cache-Control: public, max-age=3600

/badges/*
  Access-Control-Allow-Origin: *
  Cache-Control: public, max-age=86400
  Content-Type: image/svg+xml

/.well-known/x402.json
  Access-Control-Allow-Origin: *
  Cache-Control: public, max-age=3600

/.well-known/x402
  Access-Control-Allow-Origin: *
  Cache-Control: public, max-age=3600
  Content-Type: application/json; charset=utf-8
