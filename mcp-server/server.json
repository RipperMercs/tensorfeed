{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "ai.tensorfeed/mcp-server",
  "title": "TensorFeed",
  "description": "AI news, model pricing, service status, and machine-payable premium tools. AFTA-certified.",
  "version": "2.0.0",
  "websiteUrl": "https://tensorfeed.ai/developers/agent-payments",
  "repository": {
    "url": "https://github.com/RipperMercs/tensorfeed-mcp",
    "source": "github"
  },
  "remotes": [
    {
      "type": "streamable-http",
      "url": "https://mcp.tensorfeed.ai/mcp"
    }
  ],
  "packages": [
    {
      "registryType": "npm",
      "registryBaseUrl": "https://registry.npmjs.org",
      "identifier": "@tensorfeed/mcp-server",
      "version": "2.0.0",
      "runtimeHint": "npx",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "TENSORFEED_TOKEN",
          "description": "Bearer token from /api/payment/buy-credits. Required for paid tiers (full verdicts, 8 to 90 day series, webhook watches, account status). Free tiers (news, status, pricing, verdict previews, 1 to 7 day series, model discovery) work without it. Buy credits in USDC on Base at https://tensorfeed.ai/developers/agent-payments.",
          "isRequired": false,
          "isSecret": true
        }
      ]
    }
  ],
  "_meta": {
    "io.modelcontextprotocol.registry/publisher-provided": {
      "categories": ["news", "ai-models", "data", "payments"],
      "tags": ["ai-news", "x402", "usdc", "base", "model-routing", "agent-payments", "machine-payable", "stablecoin"],
      "license": "MIT",
      "premium": true,
      "premiumPaymentMethod": "USDC on Base mainnet",
      "freeTools": [
        "get_ai_news",
        "get_ai_status",
        "is_service_down",
        "get_model_pricing",
        "find_tensorfeed_data",
        "route_verdict",
        "provider_reliability_verdict",
        "x402_settlement_verdict",
        "x402_publisher_verdict",
        "stack_safety_verdict",
        "benchmark_trust_verdict",
        "failover_verdict",
        "ssvc_verdict",
        "pricing_series",
        "benchmark_series",
        "status_uptime",
        "status_leaderboard"
      ],
      "premiumTools": [
        "route_verdict",
        "provider_reliability_verdict",
        "x402_settlement_verdict",
        "x402_publisher_verdict",
        "stack_safety_verdict",
        "benchmark_trust_verdict",
        "failover_verdict",
        "ssvc_verdict",
        "pricing_series",
        "benchmark_series",
        "status_uptime",
        "status_leaderboard",
        "whats_new",
        "compare_models",
        "provider_deepdive",
        "account_status",
        "list_watches",
        "create_watch",
        "delete_watch"
      ]
    }
  }
}
